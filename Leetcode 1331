class Solution {
    public int[] arrayRankTransform(int[] arr) {
        HashMap<Integer,Integer> hm=new HashMap<>();
        int[] temp=arr.clone();
        Arrays.sort(temp);
        int r=1;
        for(int i=0;i<temp.length;i++){
            if(!hm.containsKey(temp[i])){
                hm.put(temp[i],r++);
            }
        }
        for(int i=0;i<arr.length;i++){
            arr[i]=hm.get(arr[i]);
        }
        return arr;
    }
}
