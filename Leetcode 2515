class Solution {
    public int closestTarget(String[] words, String target, int startIndex) {
        int n=words.length;
        int c=Integer.MAX_VALUE;
        for(int i=0;i<n;i++){
            if(words[i].equals(target)){
                int diff=Math.abs(i-startIndex);
                c=Math.min(c,Math.min(diff,n-diff));
            }
        }
        if(c>n){
            return -1;
        }
        else{
            return c;
        }
    }
}
