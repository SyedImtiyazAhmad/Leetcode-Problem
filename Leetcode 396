class Solution {
    public int maxRotateFunction(int[] nums) {
       int sum=0;
       int count=0;
       for(int i=0;i<nums.length;i++){
        sum+=nums[i];
        count+=i*nums[i];
       }
       int result=count;
       for(int i=0;i<nums.length;i++){
        if(i!=0){
            count+=((nums.length*nums[i-1])-sum);
            result=Math.max(result,count);
        }
       }
       return result;
    }
}
