class Solution {
    public int[] leftRightDifference(int[] nums) {
        int sum=0;
        int n=nums.length;
       for(int i=0;i<n;i++){
        sum+=nums[i];
       }
       int lsum=0;
       for(int i=0;i<n;i++){
        sum-=nums[i];
        int t=nums[i];
        nums[i]=Math.abs(sum-lsum);
        lsum+=t;
       }
       return nums;
    }
}
