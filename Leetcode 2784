class Solution {
    public boolean isGood(int[] nums) {
        Arrays.sort(nums);
        int n=nums.length;
        if(n!=nums[n-1]+1){
            return false;
        }
        else{
            for(int i=0;i<n;i++){
                if(nums[i]==i+1 ||(nums[i]==i && i==n-1)){
                    continue;
                }
                else{
                    return false;
                }
            }
        }
        return true;
    }
}
