class Solution {
    public boolean check(int[] nums) {
        boolean b=false;
       for(int i=0;i<nums.length-1;i++){
        if(b && (nums[i]>nums[i+1] || nums[i]>nums[0] || nums[i+1]>nums[0])){
            return false;
        }
        if(nums[i]>nums[i+1] && b==false){
            if(i+1==nums.length-1 && nums[i+1]>nums[0]){
                return false;
            }
            b=true;
        }
       }
       return true;
    }
}
